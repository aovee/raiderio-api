{
  "name": "raiderio-api",
  "version": "0.3.0",
  "description": "A typed Node.js client and helpers for the Raider.io API.",
  "keywords": [
    "api",
    "client",
    "mythic plus",
    "raider.io",
    "raiderio",
    "raiding",
    "warcraft",
    "world of warcraft",
    "wow"
  ],
  "license": "MIT",
  "author": "Aovee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aovee/raiderio-api.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "ky": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "@vitest/coverage-v8": "4.1.8",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "packageManager": "pnpm@10.33.0"
}
